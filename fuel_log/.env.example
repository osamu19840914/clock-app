# ============================================================
# 燃費ログ設定ファイル
# このファイルを .env という名前でコピーして値を入力してください
# ============================================================

# Notion APIトークン
# 取得方法: https://www.notion.so/my-integrations → 「新しいインテグレーション」を作成
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# NotionデータベースのID
# 取得方法: データベースをブラウザで開き、URLの以下の部分をコピー
#   https://www.notion.so/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx?v=...
#                         ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ ← この32文字
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notionのプロパティ名（実際のデータベースの列名に合わせて変更）
PROP_DATE=日付
PROP_FUEL=給油量
PROP_DISTANCE=走行距離

# ローカルサーバーのポート番号（変更不要なら 8080 のまま）
PORT=8080
